# Copy this file to .env and fill in your values.
# The .env file is gitignored — never commit your actual keys.

# ── Ollama cloud models (e.g. gemma4:31b-cloud, qwen3.5:cloud) ──────────────
# Required when llm_model in config.yaml uses an Ollama cloud model.
# Get your key at: https://ollama.com
OLLAMA_API_KEY=your_ollama_api_key_here

# ── Groq API (free tier — llama-3.3-70b-versatile etc.) ─────────────────────
# Required when llm_model starts with groq/
# Free key at: https://console.groq.com
GROQ_API_KEY=your_groq_api_key_here

# ── OpenAI (optional) ────────────────────────────────────────────────────────
# Required when llm_model starts with openai/
OPENAI_API_KEY=your_openai_api_key_here
