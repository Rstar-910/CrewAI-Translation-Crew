# Default: auto-detect text files and normalize to LF in the repo
* text=auto eol=lf

# Shell scripts must always be LF — CRLF breaks bash on Linux/macOS
*.sh text eol=lf

# Windows PowerShell scripts use CRLF on Windows, LF everywhere else
*.ps1 text eol=crlf

# Python source files — LF everywhere
*.py text eol=lf

# Config and data files — LF everywhere
*.yaml text eol=lf
*.toml text eol=lf
*.txt  text eol=lf
*.md   text eol=lf
*.env  text eol=lf
.env.example text eol=lf

# Lock files — LF (generated by uv/pip on any platform)
uv.lock text eol=lf

# Binary files — never touch line endings
*.docx binary
*.png  binary
*.jpg  binary
*.jpeg binary
*.gif  binary
*.pdf  binary
